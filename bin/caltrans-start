#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="$(
    cd "$(dirname "${BASH_SOURCE[0]}")/.." &&
    pwd
)"

cd "$PROJECT_ROOT"

if [ ! -f ".venv/bin/activate" ]; then
    echo "Virtual environment not found: $PROJECT_ROOT/.venv"
    exit 1
fi

source .venv/bin/activate

echo "Caltrans processing environment active"
echo "Project: $PROJECT_ROOT"
echo "Data: $PROJECT_ROOT/data"

exec "${SHELL:-/bin/bash}"
